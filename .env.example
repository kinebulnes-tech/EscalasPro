# ============================================================
# EscalaPro — Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local a Git (ya está en .gitignore)
# ============================================================

# --- CIFRADO LOCAL ---
# Clave AES para cifrar datos de pacientes en el navegador.
# Mínimo 32 caracteres aleatorios. Genera una en: https://1password.com/password-generator/
# Si cambias esta clave, los datos cifrados anteriores quedan inaccesibles.
VITE_ENCRYPTION_KEY=cambia-esto-por-una-clave-de-32-caracteres-min

# --- BACKEND (solo si usas el servidor Express) ---
# Dominios separados por coma que pueden llamar al backend
ALLOWED_ORIGINS=https://escalapro.cl,https://www.escalapro.cl
NODE_ENV=production
PORT=3001
